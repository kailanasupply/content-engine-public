# Environment Variables
# Copy this file to .env and fill in your real API keys
# NEVER commit .env to version control

# Required for content generation
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional — only if using Whisper for transcription
OPENAI_API_KEY=your-openai-api-key-here

# Optional — only if publishing to Notion
NOTION_API_KEY=your-notion-integration-token-here

# Optional — only if using Airtable for content calendar
AIRTABLE_API_KEY=your-airtable-personal-access-token-here
